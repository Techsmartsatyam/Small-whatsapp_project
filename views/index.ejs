<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> small Whatsapp </title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <h3> ALL CHATS</h3>
    <form  method="GET" action="/chats/new">
<button id="chats"  >New Chats!</button>
<br><br>
    </form>
     <% for(let chat of chats){ %>
        <div class="chat">
            <p> From : <%= chat.from %> </p>
            <div class="massage"> 
             <p><%= chat.msg %> </p>
            </div>
             <p> Received by : <%= chat.to %> </p>
             <hr>
                
        </div>
        <br>
        <br>
     <% } %>
</body>
</html>